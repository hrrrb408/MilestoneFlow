# MilestoneFlow Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env files containing real credentials.

# ── Database ──────────────────────────────────────────────
MF_DATASOURCE_URL=jdbc:postgresql://localhost:5432/milestoneflow
MF_DATASOURCE_USERNAME=milestoneflow
MF_DATASOURCE_PASSWORD=change-me

# ── HikariCP (optional) ──────────────────────────────────
# MF_HIKARI_MAX_POOL_SIZE=20
# MF_HIKARI_MIN_IDLE=5
